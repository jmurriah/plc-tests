	rSensorPositionAlignmentMax : REAL; (*Pulses*)
	rSensorPositionAlignmentMin : REAL; (*Pulses*)
	rSensorPositionDesired : REAL; (*Pulses*)
END_VAR
VAR CONSTANT
	iHistoryLines : USINT := 20;
END_VAR
VAR
	tonMaxTimeJogging : TON;
	xAnyManualMovement : BOOL;
	rPositionMotorMm : REAL;
	ars_AlrStop : AutoResetSound;
	ars_AlrCritical : AutoResetSound;
	ars_AlrWarning : AutoResetSound;
	ResetCommands : EdgeHoldDownCommands;
	iCancelMovement : USINT;
	iReasonWarning : UDINT;
	iReasonStop : UDINT;
	iReasonCritical : UDINT;
	StateHistory : ARRAY[0..iHistoryLines] OF EdgeHoldDownState;
	iIndexHistory : USINT;
	MotorDriveUnit : DriveUnitMngr;
	rJogSpeedSetPoint : REAL;
	xControllerReady : BOOL;
	xPoweredOn : BOOL;
	xMotorReady : BOOL;
	xAnyError : BOOL;
	xAnyManualOrder : BOOL;
	iIndexSensor : USINT;
	iAnyWarning : UINT;
	tonMotorStopped : TON;
	xMotorStopped : BOOL;
	stCriticalAlarmsLog : EventLog_typ;
	stStopAlarmsLog : EventLog_typ;
	stWarningAlarmsLog : EventLog_typ;
	iIndexIclaMotor : USINT;
	iIndexAdjustmentSystem : USINT;
	iCancelHoming : USINT;
