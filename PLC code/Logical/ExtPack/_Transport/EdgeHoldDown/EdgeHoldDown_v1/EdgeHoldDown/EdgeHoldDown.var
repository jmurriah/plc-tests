	rWidthAdjustPosition : REAL;
	rHeighAdjustPosition : REAL;
	iSystemState : EdgeHoldDownState;
	iSystemAutoState : EdgeHoldDownAutoState;
	iNumIclaMotors : USINT;
	iMisalignmentToleranceInAuto : USINT := 5;
	iMisalignmentToleranceInManual : USINT := 10;
	iSafetyOffset : USINT := 5;
	ResetCommandsSw : EdgeHoldDownCommandsSw;
