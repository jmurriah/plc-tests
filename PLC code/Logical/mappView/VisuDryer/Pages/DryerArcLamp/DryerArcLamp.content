    <Widget xsi:type="widgets.brease.TextInput" id="txtInPin" top="750" left="825" width="150" zIndex="18" />
    <Widget xsi:type="widgets.brease.Label" id="lblPower1" top="710" left="710" width="105" zIndex="19" text="$IAT/Dryer.ArcLampSN" />
    <Widget xsi:type="widgets.brease.Label" id="lblPower2" top="750" left="710" width="105" zIndex="20" text="$IAT/Dryer.ArcLampPin" />
    <Widget xsi:type="widgets.brease.Rectangle" id="recArcLamp" top="55" left="945" width="75" height="65" zIndex="21" cornerRadius="10px" backColor="rgba(0, 0, 255, 1)" />
    <Widget xsi:type="widgets.brease.ToggleButton" id="btnEnableArcLamp" top="60" left="950" width="65" height="55" zIndex="22" image="Media/UI/hw-check-dis.svg" mouseDownImage="Media/UI/hw-check.svg" cornerRadius="5px" />
    <Widget xsi:type="widgets.brease.TextOutput" id="txtOutStateLamp1" top="645" left="155" width="140" zIndex="23" value="Offline" />
    <Widget xsi:type="widgets.brease.TextOutput" id="txtOutStateLamp2" top="645" left="485" width="140" zIndex="24" value="Offline" />
